# Fair Migration — serverless environment variables (set in Vercel: Production + Preview)
# Redeploy after changing any of these.

# --- Airtable (required for all /api routes) ---
AIRTABLE_API_KEY=                 # Personal access token. Scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_BASE_ID=                 # appXXXXXXXXXXXXXX
# Optional table-name overrides (defaults shown)
AIRTABLE_CONTACTS_TABLE=Contacts
AIRTABLE_EVENTS_TABLE=Events
AIRTABLE_PETITION_SIGNATURES_TABLE=Petition Signatures
AIRTABLE_DONATIONS_TABLE=Donations

# --- Stripe (required for donations) ---
STRIPE_SECRET_KEY=                # Restricted key: read Checkout Sessions + Customers + Invoices + Subscriptions
STRIPE_WEBHOOK_SECRET=            # whsec_… from the webhook endpoint you register

# --- Meta Conversions API (optional; Lead + Purchase server events) ---
META_PIXEL_ID=
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=             # optional, Test Events only

# --- Site config ---
PRODUCTION_ORIGIN=https://fairmigration.vote
ALLOWED_ORIGINS=                  # optional, extra comma-separated origins for CORS
