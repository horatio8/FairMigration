# Fair Migration — serverless environment variables (Vercel: Preview + Production).
# Redeploy after changes. Verify with GET /api/admin/env-check (basic-auth; ?live=1 pings).

# ============ REQUIRED (core: petitions + donations + referral) ============
AIRTABLE_API_KEY=                 # PAT. Scopes: data.records:read, data.records:write, schema.bases:read
AIRTABLE_BASE_ID=app9pnP8DII9lzo2u   # "Fair Migration — Tracking"
STRIPE_SECRET_KEY=                # read Checkout Sessions + Customers + Invoices + Subscriptions
STRIPE_WEBHOOK_SECRET=            # whsec_… from the webhook endpoint
CRON_SECRET=                      # Bearer for Vercel cron + manual ?key= calls
ADMIN_BASIC_AUTH=user:pass        # gates /leaderboard, /api/ab-report, /api/admin/*

# Airtable table-name overrides (defaults already match the created base)
# AIRTABLE_CONTACTS_TABLE=Contacts
# AIRTABLE_EVENTS_TABLE=Events
# AIRTABLE_DONATIONS_TABLE=Donations
# AIRTABLE_PETITION_SIGNATURES_TABLE=Petition Signatures
# AIRTABLE_LAPSE_TABLE=Lapse Queue
# AIRTABLE_SMS_SENDS_TABLE=SMS Sends
# AIRTABLE_SMS_REPLIES_TABLE=SMS Replies
# AIRTABLE_REFERRAL_ROLLUP_TABLE=Referral Rollup
# AIRTABLE_AB_DAILY_TABLE=AB Daily
# AIRTABLE_STATS_TABLE=Site Stats
# AIRTABLE_RALLY_TICKETS_TABLE=Rally Tickets
# AIRTABLE_RALLY_COMP_TOKENS_TABLE=Rally Comp Tokens

# ============ Meta (optional) ============
META_PIXEL_ID=
META_CAPI_TOKEN=
META_TEST_EVENT_CODE=
# native Meta Lead Ads webhook (alt to Zapier → /api/event-log):
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=

# ============ Cellcast SMS (optional) ============
CELLCAST_API_KEY=
CELLCAST_FROM=                    # sender id; leave unset to keep two-way replies
CELLCAST_API_BASE=https://api.cellcast.com/api/v1
CELLCAST_WEBHOOK_BASIC=user:pass  # for POST /api/cellcast-inbound
CELLCAST_FORWARD_URL=
SMS_QUIET_START=08:00
SMS_QUIET_END=20:00
SMS_DELAY_MIN_S=15
SMS_DELAY_MAX_S=55
SMS_INCLUDE_CONTACT_REF=1         # "0" disables ?c= append
AB_FORCE_VARIANT=off              # off | A | B

# ============ Campaign Nucleus email (optional) ============
CN_API_KEY=
CN_API_BASE=https://api.campaignnucleus.com/v1
CN_RECEIVER_URLS=                 # JSON { "<slug>": "<receiver URL>", "_default": "…" }
CN_AUTOMATION_PETITION_LAPSE_A=
CN_AUTOMATION_PETITION_LAPSE_B=
CN_AUTOMATION_DONATION_LAPSE_A=
CN_AUTOMATION_DONATION_LAPSE_B=

# ============ Rally ticketing (optional, separate Stripe account) ============
STRIPE_RALLY_SECRET_KEY=
STRIPE_RALLY_PUBLISHABLE_KEY=
STRIPE_RALLY_WEBHOOK_SECRET=
STRIPE_RALLY_ADULT_PRICE_ID=
STRIPE_RALLY_KID_PRICE_ID=
RALLY_SUCCESS_URL_BASE=
RALLY_COMP_TOKEN_FALLBACK=

# ============ Signature counter / misc ============
SIGNATURE_BASE_OFFSET=69500
SIGNATURE_ROUND_DOWN_TO=
SIGNATURE_MILESTONES=90000,95000,100000
MILESTONE_WEBHOOK_URL=
YOUTUBE_CHANNEL_ID=
PRODUCTION_ORIGIN=https://fairmigration.vote
ALLOWED_ORIGINS=
